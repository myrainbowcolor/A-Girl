# 复制为 backend/.env 后按需修改
#
# 策略：默认启动 = 真实 LLM；mock 仅用于 pytest / CI（见 backend/tests/conftest.py）
# 推荐：bash scripts/start-remote-llm.sh 自动生成本文件并启动 LLM

# ── LLM（用户聊天必配其一）──

# 本机 Ollama（推荐有 GPU/本机 Ollama 时）
AGIRL_LLM_PROVIDER=openai_compatible
AGIRL_LLM_BASE_URL=http://127.0.0.1:11434/v1
AGIRL_LLM_API_KEY=ollama
AGIRL_LLM_MODEL=llama3

# Cloud Agent / 无 Ollama：自动下载 GGUF + llama-cpp，脚本会写为：
#   Linux:   bash scripts/start-remote-llm.sh
#   Windows: powershell -ExecutionPolicy Bypass -File scripts\start-remote-llm.ps1
#   游戏 NPC: bash scripts/start-local-game.sh 或 scripts\start-local-game.ps1
# AGIRL_LLM_BASE_URL=http://127.0.0.1:11435/v1
# AGIRL_LLM_API_KEY=local
# AGIRL_LLM_MODEL=qwen2.5-0.5b-instruct

# 云端 API（DeepSeek / OpenAI 等）
# AGIRL_LLM_BASE_URL=https://api.deepseek.com/v1
# AGIRL_LLM_API_KEY=sk-xxx
# AGIRL_LLM_MODEL=deepseek-chat

# 本地小模型（如 Qwen 0.5B）质量不稳时，用场景引擎补位（加班/宠物/情绪等分支逻辑）
AGIRL_LLM_MOCK_FALLBACK=true

# ── 勿用于实际聊天 ──
# AGIRL_LLM_PROVIDER=mock   # 仅 pytest/CI；关键词模板，听不懂自由对话

# ── 语音（免费推荐 Edge TTS，无需 Key）──
AGIRL_TTS_PROVIDER=edge
AGIRL_EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
AGIRL_STT_PROVIDER=mock

# 付费/自托管 OpenAI 兼容语音：
# AGIRL_TTS_PROVIDER=openai_compatible
# AGIRL_VOICE_BASE_URL=https://api.openai.com/v1
# AGIRL_VOICE_API_KEY=sk-xxx

# ── 情感与关系（可选）──
# AGIRL_SENTIMENT_MODE=hybrid
# AGIRL_RELATIONSHIP_SUMMARY_EVERY_N=3

# ── 本地调试 ──
# AGIRL_REQUIRE_AGE_GATE=false
