{
  "id": "long_chat_consistency",
  "name": "长对话一致性",
  "description": "模拟较长对话后仍保持自然口语，不出现机器模板。",
  "tags": ["场景:长聊", "关系:升温", "情绪:混合", "时长:长对话"],
  "setup": {
    "warmup": [
      "嗨，在吗",
      "今天加班好累",
      "不过项目终于上线了，有点开心",
      "谢谢你一直听我说",
      "对了，我喜欢喝奶茶",
      "下次想带你去那家店"
    ]
  },
  "turns": [
    {
      "user": "跟你聊了这么久，感觉你挺懂我的",
      "assert": {
        "forbidden_extra": ["我听到你说", "愉悦度"],
        "any_keywords": ["懂", "陪", "聊", "开心", "谢"],
        "affinity_min": 10,
        "max_sentences": 5,
        "llm_not": "safety"
      }
    }
  ],
  "developer_notes": "长对话后忌突然切换客服腔或报数值。"
}
